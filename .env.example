# ---------------------------------------------------------------------------
# Environment variables for the portfolio. Copy this file to `.env.local`:
#
#   cp .env.example .env.local
#
# `.env.local` is gitignored and must never be committed.
# ---------------------------------------------------------------------------

# Groq API key — powers the "interview me" AI chat (server-side only).
# Get a free key (no credit card) at https://console.groq.com/keys
# Free tier is generous (thousands of requests/day) — plenty for a portfolio.
# Without this key the site still runs; only the AI chat shows a friendly notice.
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
